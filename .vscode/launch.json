{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "type": "java",
            "name": "RPNPrinter",
            "request": "launch",
            "mainClass": "com.lox.RPNPrinter",
            "projectName": "demo"
        },
        {
            "type": "java",
            "name": "AstPrinter",
            "request": "launch",
            "mainClass": "com.lox.AstPrinter",
            "projectName": "demo"
        },
        {
            "type": "java",
            "name": "Current File",
            "request": "launch",
            "mainClass": "${file}"
        },
        {
            "type": "java",
            "name": "Lox",
            "request": "launch",
            "mainClass": "com.lox.Lox",
            "projectName": "demo"
        },
        {
            "type": "java",
            "name": "GenerateAst",
            "request": "launch",
            "mainClass": "com.tool.GenerateAst",
            "projectName": "demo",
            "args": "${workspaceFolder}/src/main/java/com/lox"
        }
    ]
}